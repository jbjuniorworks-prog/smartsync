# Credenciais do Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua-service-key-secreta-aqui

# Segredo para assinar os tokens JWT (use um valor longo e aleatório)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Origens permitidas no CORS (separadas por vírgula) — o domínio do frontend
ALLOWED_ORIGINS=http://localhost:3000,https://smartsync-two.vercel.app

# Porta do servidor (opcional)
PORT=5000

# Senhas iniciais do seed (opcional; troque em produção)
SEED_ADMIN_PASS=admin123
SEED_VENDEDOR_PASS=vend123
